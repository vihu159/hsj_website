# Canonical site URL (for metadata, OpenGraph, JSON-LD). e.g. https://hsjjewellers.com
# NEXT_PUBLIC_SITE_URL=https://hsjjewellers.com

# Show gateway at / first (Admin | View website). Set to true for local use.
NEXT_PUBLIC_ADMIN_FIRST=true

# Require login for /admin. Set to "true" to enable password; leave unset for open admin.
# REQUIRE_ADMIN_AUTH=true
# ADMIN_PASSWORD=your-secure-password
